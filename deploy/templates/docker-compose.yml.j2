# ZEN70 容器编排 - 由 config-compiler 生成
# 生成时间: {{ now() }}
# 版本: docker-compose v3.8+
# 容器安全基线：非 root、只读根、cap_drop、资源限制、healthcheck（见 .cursorrules 3.3）

version: '3.8'

networks:
  zen70_net:
    driver: bridge

services:
{% for name, svc in (services | default({})).items() %}
{% if svc.enabled is defined and svc.enabled %}
  {{ name }}:
    image: {{ svc.image }}
    container_name: zen70-{{ name }}
    restart: unless-stopped
{# 安全基线：仅在 svc.security.apply_baseline=true 时启用，避免破坏 postgres/redis 等需特权的服务 #}
{% if (svc.security or {}).apply_baseline | default(false) %}
    user: {{ (svc.security or {}).user | default("1000:1000") }}
    read_only: true
    cap_drop:
      - ALL
{% endif %}
{% if svc.volumes is defined and svc.volumes %}
    volumes:
{% for vol in svc.volumes %}
      - {{ vol }}
{% endfor %}
{% endif %}
{% if svc.environment is defined and svc.environment %}
    environment:
{% for key, value in svc.environment.items() %}
      - {{ key }}={{ value }}
{% endfor %}
{% endif %}
{% if svc.ports is defined and svc.ports %}
    ports:
{% for port in svc.ports %}
      - {{ port }}
{% endfor %}
{% endif %}
{% if svc.depends_on is defined and svc.depends_on %}
    depends_on:
{% for dep in svc.depends_on %}
      - {{ dep }}
{% endfor %}
{% endif %}
{% if (svc.security or {}).mem_limit is defined %}
    mem_limit: {{ svc.security.mem_limit }}
{% elif security_defaults is defined and security_defaults.mem_limit is defined %}
    mem_limit: {{ security_defaults.mem_limit }}
{% endif %}
{% if (svc.security or {}).cpus is defined %}
    cpus: {{ svc.security.cpus }}
{% elif security_defaults is defined and security_defaults.cpus is defined %}
    cpus: {{ security_defaults.cpus }}
{% endif %}
{% if (svc.healthcheck or {}).test is defined %}
    healthcheck:
      test: {{ svc.healthcheck.test | tojson }}
      interval: {{ svc.healthcheck.interval | default("30s") }}
      timeout: {{ svc.healthcheck.timeout | default("10s") }}
      retries: {{ svc.healthcheck.retries | default(3) }}
{% endif %}
    networks:
      - zen70_net
{% endif %}
{% endfor %}
