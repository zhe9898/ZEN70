# ZEN70 环境变量 - 由 config-compiler 生成
# 生成时间: {{ now() }}
# 敏感信息使用占位，由点火脚本注入

# 数据库配置
POSTGRES_PASSWORD={{ (services | default({})).get('postgres', {}).get('environment', {}).get('POSTGRES_PASSWORD', '${POSTGRES_PASSWORD}') }}

# Redis 配置
REDIS_HOST={{ redis_host | default('redis') }}
REDIS_PORT={{ redis_port | default(6379) }}

# JWT 双轨（法典强制）
JWT_SECRET_CURRENT={{ jwt_secret_current | default(generate_secret()) }}
JWT_SECRET_PREVIOUS={{ jwt_secret_previous | default('') }}

# 多模态超时（秒）
MULTIMODAL_TIMEOUT_SECONDS={{ multimodal_timeout | default(8.0) }}

# 域名 / 网络
DOMAIN={{ (network | default({})).get('domain', 'home.zen70.local') }}
