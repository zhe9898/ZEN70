# ZEN70 API 网关环境变量示例
# 复制为 .env 并按需修改

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 可选：健康检查会尝试 TCP 连接
POSTGRES_DSN=postgresql://zen70:password@localhost:5432/zen70

# 逗号分隔的允许源，* 表示全部（生产建议限制域名）
CORS_ORIGINS=http://localhost:5173,https://home.zen70.cn

LOG_LEVEL=INFO

# -------------------- 认证 (WebAuthn + JWT 双轨 + PIN 降级) --------------------
# 当前 JWT 签名密钥（必填；生产请用强随机值）
JWT_SECRET_CURRENT=your-current-secret-change-in-production
# 上一轮密钥（可选）；旧令牌验证通过时签发新令牌并通过 X-New-Token 返回
JWT_SECRET_PREVIOUS=
# 访问令牌有效期（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# WebAuthn RP ID，取 DOMAIN 的主机部分（如 home.zen70.cn 或 localhost）
DOMAIN=home.zen70.cn
# PIN 码哈希盐（可选；bcrypt 自带盐，此变量可留空或用于额外配置）
# PIN_CODE_SALT=
