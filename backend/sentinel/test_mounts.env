# 拓扑探针测试环境变量（Mock 模式）
# 使用方式: export $(grep -v '^#' test_mounts.env | xargs)  (Linux/macOS)
# 或逐行 source / set (Windows)

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
MOCK_HARDWARE=true
PROBE_INTERVAL=2
DEBOUNCE_WINDOW=3
# 格式: path,uuid,min_space_gb; path2,uuid2,min_gb (uuid 可留空)
MOUNT_POINTS=/mnt/fake1,,1;/mnt/fake2,123e4567-e89b-12d3-a456-426614174000,2
