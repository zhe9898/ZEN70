    "/api/v1/stream/ping": {
      "post": {
        "summary": "Stream Ping",
        "description": "法典 2.1.1：前端每 30s 调此接口续期，否则 45s 后服务端 cancel SSE。",
        "operationId": "stream_ping_api_v1_stream_ping_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
