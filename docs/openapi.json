  "components": {
    "schemas": {
      "CapabilityItem": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "online | pending_maintenance | unknown"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "description": "是否可交互"
          },
          "endpoint": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Endpoint",
            "description": "绑定的内网或外网端点"
          },
          "models": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Models",
            "description": "携带的具体模型数组"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason",
            "description": "状态或异常附加说明"
          }
        },
        "type": "object",
        "required": [
          "status",
          "enabled"
        ],
        "title": "CapabilityItem",
        "description": "单个能力：status=online 则 enabled，PENDING_MAINTENANCE 则 disabled。"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PingRequest": {
        "properties": {
          "connection_id": {
            "type": "string",
            "title": "Connection Id",
            "description": "SSE 连接建立时下发的 ID"
          }
        },
        "type": "object",
        "required": [
          "connection_id"
        ],
        "title": "PingRequest",
        "description": "Ping 请求体：前端每 30s 调用，防 45s 超时 cancel。"
      },
      "ShredRequest": {
        "properties": {
          "file_path": {
            "type": "string",
            "title": "File Path",
            "description": "宿主机或容器内待物理粉碎的绝对路径"
          }
        },
        "type": "object",
        "required": [
          "file_path"
        ],
        "title": "ShredRequest",
        "description": "法典 3.3.2 - 数据可携带权与安全剿灭"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
