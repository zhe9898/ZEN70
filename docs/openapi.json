    "/api/v1/stream": {
      "get": {
        "summary": "Stream",
        "description": "法典 2.1.1：SSE 单向推送。前端每 30s 调 POST /api/v1/stream/ping 续期，\n后端 45s 未收到必须 cancel() 释放 FD，杜绝半开连接耗尽资源。",
        "operationId": "stream_api_v1_stream_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
