    "/api/v1/storage/shred": {
      "delete": {
        "summary": "Secure Shredding",
        "description": "法典 3.3.2: 安全覆写销毁 (Secure Shredding)。\n严禁使用 os.remove()。必须调用 Linux shred 指令\n执行 3 次随机覆写并以零结尾，确保数据不可物理恢复。",
        "operationId": "secure_shredding_api_v1_storage_shred_delete",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
