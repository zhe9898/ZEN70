    "/api/v1/capabilities": {
      "get": {
        "summary": "Capabilities",
        "description": "法典 2.3.1：返回能力矩阵，供前端 v-for 动态渲染。\n基于 BFF 定义：根据登录者 role 决定下发的 JSON 视图积木。",
        "operationId": "capabilities_api_v1_capabilities_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "$ref": "#/components/schemas/CapabilityItem"
                  },
                  "type": "object",
                  "title": "Response Capabilities Api V1 Capabilities Get"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
