@echo off
chcp 65001 >nul
echo =========================================================
echo            ZEN70 V2.1 一键销毁引擎 (Teardown Engine)
echo =========================================================

echo.
echo [1/2] 正在向后台物理探针发送截断指令与休眠...
taskkill /F /FI "WINDOWTITLE eq ZEN70_Sentinel*" /T >nul 2>&1

echo.
echo [2/2] 正在销毁 Docker 业务容器栈并释放所有端口与宿主网卡...
docker compose -p zen70 down

echo.
echo =========================================================
echo ✅ ZEN70 系统已全部安全下线，宿主资源已100%%释放。
echo =========================================================
pause
