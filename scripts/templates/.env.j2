# ZEN70 环境变量 - 由 scripts/compiler.py 生成
# 生成时间: {{ now }}
# 敏感信息由点火脚本注入

# 数据库
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_DSN=postgresql://{{ postgres_user }}:{{ postgres_password }}@pgbouncer:5432/{{ postgres_db }}

# Redis
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
REDIS_USER={{ redis_user }}
REDIS_PASSWORD={{ redis_password }}

# JWT 双轨
JWT_SECRET_CURRENT={{ jwt_secret_current }}
JWT_SECRET_PREVIOUS={{ jwt_secret_previous }}

# 网络
DOMAIN={{ domain }}

# 隧道 Token（法典 1.2：严禁硬编码，缺失时占位供手动填入）
TUNNEL_TOKEN={{ tunnel_token }}
CLOUDFLARED_TUNNEL_TOKEN={{ tunnel_token }}

# 容灾引擎
BACKUP_ENABLED={{ backup_enabled }}

# AI 目标后端（法典解耦：绝不允许 AI_BACKEND_URL 代码写死）
AI_BACKEND_URL={{ ai_backend_url }}

# 路径解耦（法典 1.2）：唯一事实来源 system.yaml → 此处，代码禁止硬编码路径
MEDIA_PATH={{ media_path }}
BITROT_SCAN_DIRS={{ bitrot_scan_dirs }}
MOUNT_CONTAINER_MAP='{{ mount_container_map }}'
WATCH_TARGETS='{{ watch_targets }}'
SWITCH_CONTAINER_MAP='{{ switch_container_map }}'

# 供应链（法典 1.1）：私有镜像仓库，启用时由点火脚本注入
REGISTRY_URL=
REGISTRY_USER=
REGISTRY_PASSWORD=
